# ─── Supabase ──────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Public Supabase URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URL ───────────────────────────────────────────────────────────────
# Used for OAuth redirects and CSRF origin validation.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email ─────────────────────────────────────────────────────────────────
# Get your key at: resend.com → API Keys

RESEND_API_KEY=

# ─── AI ────────────────────────────────────────────────────────────────────
# Get your key at: console.anthropic.com → API Keys

ANTHROPIC_API_KEY=
