      "parameters": {
        "jsCode": "// Input date string, e.g. \"2025-11-06T10:09:16.026-05:00\"\nconst currentDate = String($input.first().json.currentDate);\n\n// Parse ISO date and convert to Canada Eastern Time\nconst dateObj = new Date(currentDate);\n\n// Format output as \"YYYY-MM-DD | HH:mm\" in America/Toronto timezone\nconst options = {\n  timeZone: 'America/Toronto',\n  year: 'numeric',\n  month: '2-digit',\n  day: '2-digit',\n  hour: '2-digit',\n  minute: '2-digit',\n  hour12: false\n};\n\nconst localeStr = dateObj.toLocaleString('en-CA', options).replace(',', '');\nconst [dateCA, timeCA] = localeStr.split(' ');\nconst formatted = `${dateCA} | ${timeCA}`;\n\nreturn [{ json: { formatted } }];\n"
      },
