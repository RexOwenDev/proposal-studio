  {
    "parameters": {
      "jsCode": "const items = $input.all();\nconst filtered = items.filter(item => {\n  const row = item.json;\n  return (\n    row[\"URL\"] && row[\"URL\"].trim() !== \"\" &&\n    (!row[\"TITLE\"] || row[\"TITLE\"].trim() === \"\") &&\n    (!row[\"STATUS LOG\"] || row[\"STATUS LOG\"].trim() === \"\")\n  );\n});\nreturn filtered;"
    },
