  {
    "parameters": {
      "sendTo": "={{ $json['Email Address'] }}",
      "subject": "=Your Application Has Been Approved",
      "message": "=<!doctype html>\n<html>\n    <head>\n        <meta charset=\"utf-8\" />\n        <meta name=\"viewport\" content=\"width=device-width\" />\n        <title>Reminder: Documents Needed to Complete OUR Review</title>\n        <style>\n            @media only screen and (max-width: 620px) {\n                .container {\n                    width: 100% !important;\n                }\n                .stack {\n                    display: block !important;\n                    width: 100% !important;\n                }\n                .pad {\n                    padding-left: 16px !important;\n                    padding-right: 16px !important;\n                }\n            }\n            img {\n                border: 0;\n                -ms-interpolation-mode: bicubic;\n                display: block;\n            }\n            a {\n                color: inherit;\n                text-decoration: none;\n            }\n        </style>\n    </head>\n    <body\n        style=\"\n            margin: 0;\n            padding: 0;\n            background-color: #f4f4f4;\n            font-family: Arial, Helvetica, sans-serif;\n            -webkit-text-size-adjust: 100%;\n            -ms-text-size-adjust: 100%;\n        \"\n    >\n        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\" role=\"presentation\">\n            <tr>\n                <td align=\"center\" style=\"padding: 20px 10px\">\n                    <table\n                        class=\"container\"\n                        cellpadding=\"0\"\n                        cellspacing=\"0\"\n                        border=\"0\"\n                        width=\"600\"\n                        role=\"presentation\"\n                        style=\"\n                            width: 600px;\n                            max-width: 600px;\n                            background-color: #ffffff;\n                            border-radius: 6px;\n                            overflow: hidden;\n                        \"\n                    >\n                        <tr>\n                    \t\t<td style=\"padding:30px;background-color: #00314D;\">\n                    \t\t\t<p style=\"margin: 0; width: 100%;text-align: center; color: #fff; font-size: 13px; line-height: 24px;\"><b><span style=\"color:#E03431;\">QUICK & EASY APPROVALS.</span> STRAIGHTFORWARD PROCESS.</b></p>\n                    \t\t</td>\n                    \t</tr>\n                        <tr>\n                            <td style=\"padding: 30px; text-align: center; background-color: #ffffff\">\n                                <img\n                                    src=\"http://canadianmerchantcashadvance.ca/wp-content/uploads/2025/11/logo-cmca.png\"\n                                    alt=\"CMCA Finance\"\n                                    width=\"160\"\n                                    style=\"display: block; border: 0; outline: none; text-decoration: none; margin: auto;\"\n                                />\n                            </td>\n                        </tr>\n                        <tr>\n                            <td class=\"pad\" style=\"padding: 10px 45px; color: #515967;\">\n                                <p style=\"margin: 0 0 16px 0; font-size: 18px; font-weight: 700; line-height: 24px; color: #15243C;\">Hello,</p>\n                                <p style=\"margin: 0 0 30px 0; font-size: 18px; font-weight: 700; line-height: 24px; color: #15243C;\">\n                                    Good news \u00e2\u20ac\u201d your application for funding has been approved.\n                                </p>\n                                <p style=\"margin: 0 0 30px 0; font-size: 15px; font-weight: 400; line-height: 22px; color: #515967;\">\n                                    Our underwriting team has completed the initial assessment and determined that your business qualifies to move forward.\n                                </p>\n                                <p style=\"max-width: 460px; margin: 0 auto 24px; font-size: 12px; font-weight: 400; line-height: 22px; color: #515967;\">\n                                    The next step is for us to connect and review the lending options available based on your file. During this call, we\u00e2\u20ac\u2122ll walk you through the approved amounts, terms, and the structure that best supports your business.\n                                </p>\n                                <p style=\"max-width: 460px; margin: 0 auto 24px; font-size: 12px; font-weight: 400; line-height: 22px; color: #515967;\">\n                                    We will contact you directly using the number on file to schedule this review. Once we connect, we\u00e2\u20ac\u2122ll finalize the details and guide you through the remaining steps.\n                                </p>\n                                <p style=\"max-width: 460px; margin: 0 auto 30px; font-size: 12px; font-weight: 400; line-height: 22px; color: #515967;\">\n                                    We look forward to assisting you.<br/><b><i>Thank you for choosing CMCA</i></b>\n                                </p>\n                                <div style=\"display: block; max-width: 460px; width: 100%; margin: 0 auto; height: 1px; background-color: #E1E6EF;\"></div>\n                            </td>\n                        </tr>\n                        <tr>\n                            <td>\n                                <p style=\"display: block; max-width: 510px; margin: 30px auto; font-size: 17px; font-weight: 700; line-height: 22px; text-align: center; color: #C5221F;\">CMCA is committed to responsible, secure, and transparent lending.</p>\n                                <table\n                                    width=\"460\"\n                                    cellpadding=\"0\"\n                                    cellspacing=\"0\"\n                                    border=\"0\"\n                                    role=\"presentation\"\n                                    style=\"margin: 0 auto;\"\n                                >\n                                    <tr>\n                                        <td>\n                                            <p style=\"font-size: 13px; font-weight: 400; line-height: 22px; text-align: center; color: #15243C;\">We are accredited by the Better Business Bureau</p>\n                                            <p style=\"margin:0; display: block; text-align: center;\">\n                                                <img src=\"http://canadianmerchantcashadvance.ca/wp-content/uploads/2025/11/logo-bbb.png\" width=\"150\" style=\"display: inline-block;\" />\n                                            </p>\n                                        </td>\n                                        <td>\n                                            <p style=\"font-size: 13px; font-weight: 400; line-height: 22px; text-align: center; color: #15243C;\">Proud member of the Canadian Lender Association</p>\n                                            <p style=\"margin:0; display: block; text-align: center;\">\n                                                <img src=\"http://canadianmerchantcashadvance.ca/wp-content/uploads/2025/11/logo-cla.png\" width=\"150\" style=\"display: inline-block;\" />\n                                            </p>\n                                        </td>\n                                    </tr>\n                                    <tr>\n                                        <td colspan=\"2\">\n                                            <p style=\"margin: 30px auto; font-size: 12px; font-weight: 400; line-height: 19px; text-align: center; font-style: italic; color: #15243C;\">Note: If you prefer to complete a PDF version of the application instead, simply reply to this email to request the form. Docusign is the preferred method.</p>\n                                            <div style=\"display: block; max-width: 460px; width: 100%; margin: 0 auto; height: 1px; background-color: #E1E6EF;\"></div>\n                                        </td>\n                                    </tr>\n                                </table>\n                            </td>\n                        </tr>\n                        <tr>\n                            <td>\n                                <table\n                                    width=\"460\"\n                                    cellpadding=\"0\"\n                                    cellspacing=\"0\"\n                                    border=\"0\"\n                                    role=\"presentation\"\n                                    style=\"margin: 0 auto;\"\n                                >\n                                    <p style=\"text-align: center; font-size: 10px; font-weight: 400; line-height: 17px; color: #515967; margin-top:30px;\"><b>CMCA \u00e2\u20ac\u201c Canadian Merchant Cash Advance</b><br/>Underwriting & Client Services</p>\n                                    <p style=\"text-align: center; font-size: 10px; font-weight: 400; line-height: 17px; color: #515967;margin-bottom:30px;\"><b>CMCA Finance\u00c2\u00ae Corporate Office</b><br/>309 Lakeshore Blvd. Pointe-Claire, QC H9S 4L6<br/>Phone: <a href=\"tel:18556512844\">1-855-651-2844</a><br/>Fax: <a href=\"tel:18555416893\">1-855-541-6893</a><br/><a href=\"www.canadianmerchantcashadvance.ca\" target=\"_blank\">www.canadianmerchantcashadvance.ca</a>&nbsp;&nbsp;&nbsp;<a href=\"mailto:underwriting@cmcafinance.com\" target=\"_blank\">underwriting@cmcafinance.com</a></p>\n                                </table>\n                            </td>\n                        </tr>\n                    </table>\n                </td>\n            </tr>\n        </table>\n    </body>\n</html>\n",
      "options": {
        "appendAttribution": false
      }
    },
