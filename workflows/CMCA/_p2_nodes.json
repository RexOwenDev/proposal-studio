  {
    "parameters": {
      "jsCode": "const entryDate = $input.first().json.currentDate; // Expects ISO 8601 string with timezone\n\n// Parse ISO string into Date object\nconst dateObj = new Date(entryDate);\n\n// Options for 'MMMM D, YYYY at h:mm a'\nconst options1 = {\n  timeZone: 'America/Toronto',\n  year: 'numeric',\n  month: 'long',\n  day: 'numeric',\n  hour: 'numeric',\n  minute: '2-digit',\n  hour12: true,\n};\nconst entry_datetime = dateObj.toLocaleString('en-CA', options1).replace(',', ' at');\n\n// Options for 'YYYY-MM-DD | HH:mm'\nconst options2 = {\n  timeZone: 'America/Toronto',\n  year: 'numeric',\n  month: '2-digit',\n  day: '2-digit',\n  hour: '2-digit',\n  minute: '2-digit',\n  hour12: false,\n};\nconst localeStr2 = dateObj.toLocaleString('en-CA', options2).replace(',', '');\nconst [dateCA, timeCA] = localeStr2.split(' ');\nconst log_datetime = `${dateCA} | ${timeCA}`;\n\nreturn [\n  {\n    json: {\n      entry_datetime,\n      log_datetime,\n    }\n  }\n];\n"
    },
