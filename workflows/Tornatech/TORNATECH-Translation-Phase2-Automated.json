    {
      "id": "t2-003",
      "name": "Split Posts into Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1200,
        0
      ],
      "parameters": {
        "jsCode": "const input = $input.item.json;\n\n// Case 1: HTTP Request already split the array \u00e2\u20ac\u201d input is a single post object\nif (!Array.isArray(input)) {\n  if (!input || typeof input !== 'object' || !input.id) return [];\n  return [{ json: input }];\n}\n\n// Case 2: HTTP Request returned the full array as one item\nif (input.length === 0) return [];\nreturn input.map(post => ({ json: post }));"
      },
      "onError": "continueRegularOutput"
    },
