    {
      "id": "t2-007",
      "name": "Validate FR JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "parameters": {
        "jsCode": "const msgContent = $input.item.json.choices?.[0]?.message?.content;\nlet parsed;\nif (typeof msgContent === 'object' && msgContent !== null) {\n  parsed = msgContent;\n} else {\n  try {\n    const cleaned = String(msgContent).replace(/^```json\\n?/, '').replace(/\\n?```$/, '').trim();\n    parsed = JSON.parse(cleaned);\n  } catch (e) {\n    throw new Error('FR Translation returned invalid JSON: ' + String(msgContent).substring(0, 200));\n  }\n}\nif (!parsed.title || !parsed.content) {\n  throw new Error('FR Translation JSON missing required keys. Got: ' + Object.keys(parsed).join(', '));\n}\nconst originalLength = $('Fetch Full Post').item.json.content.rendered.length;\nif (parsed.content.length < originalLength * 0.4) {\n  throw new Error('FR translated content suspiciously short (' + parsed.content.length + ' vs original ' + originalLength + ')');\n}\nreturn [{ json: { title_fr: parsed.title, content_fr: parsed.content } }];"
      },
      "onError": "continueRegularOutput"
    },
