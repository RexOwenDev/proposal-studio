    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\n\n// Case 1: HTTP Request already split the array — input is a single post object\nif (!Array.isArray(input)) {\n  if (!input || typeof input !== 'object' || !input.id) return [];\n  return [{ json: input }];\n}\n\n// Case 2: HTTP Request returned the full array as one item\nif (input.length === 0) return [];\nreturn input.map(post => ({ json: post }));"
      },
