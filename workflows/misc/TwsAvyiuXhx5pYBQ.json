    {
      "parameters": {
        "jsCode": "const html = $input.first().json.body;\n\n// Load the cheerio library\nconst cheerio = require('cheerio');\n\n// Parse HTML using cheerio\nconst $ = cheerio.load(html);\n\n// Get all <img> elements\nconst images = $('img');\n\nlet results = [];\n\nimages.forEach(img => {\n    results.push({\n        src: $(img).attr('src') || '',\n        alt: $(img).attr('alt') || ''\n    });\n});\n\n// Return as n8n items\nreturn results.map(item => ({ json: item }));"
      },
